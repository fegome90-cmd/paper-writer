{
  // ── Python ──────────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.languageServer": "Pylance",
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.extraPaths": ["${workspaceFolder}"],
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests"],
  "python.testing.unittestEnabled": false,

  // ── Ruff (lint + format) ────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "ruff.organizeImports": true,
  "ruff.fixAll": true,

  // ── TOML ────────────────────────────────────────────────────────────────
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // ── YAML ────────────────────────────────────────────────────────────────
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.schemas": {
    // state.yaml gate schema — detecta el archivo de estado del pipeline
    "file://${workspaceFolder}/docs/state-schema.json": "outputs/state.yaml"
  },

  // ── Vale (estilo editorial) ──────────────────────────────────────────────
  "vale.valePath": "/opt/homebrew/bin/vale",
  "vale.core.useCLI": true,

  // ── Pandoc Citer ────────────────────────────────────────────────────────
  // Apunta al .bib activo del workspace para autocompletar @citekey
  "pandoc-citer.DefaultBib": "${workspaceFolder}/outputs/manuscript/references.bib",

  // ── Markdown ─────────────────────────────────────────────────────────────
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.wordWrap": "on"
  },

  // ── Editor general ───────────────────────────────────────────────────────
  "editor.rulers": [100],
  "editor.tabSize": 4,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ── Exclusiones ──────────────────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/*.egg-info": true,
    "**/.venv": true
  },

  // ── Makefile Tools ───────────────────────────────────────────────────────
  "makefile.launchConfigurations": [
    { "launchTarget": "verify" },
    { "launchTarget": "test" },
    { "launchTarget": "lint" },
    { "launchTarget": "typecheck" }
  ]
}
