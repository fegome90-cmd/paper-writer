# Zotero Configuration
# Required: Your Zotero user ID (find at https://www.zotero.org/settings/keys)
ZOTERO_USER_ID=
# Required (cloud mode): API key with library access
ZOTERO_API_KEY=
# Optional: "user" (default) or "group"
ZOTERO_LIBRARY_TYPE=user
# Optional: "true" to use Zotero 7 local API at localhost:23119
ZOTERO_LOCAL=false
# Optional: "true" to use Better BibTeX local pull endpoint
ZOTERO_BBT_LOCAL=false

# Search Provider
# Optional: "fixture" (default), "openalex", "crossref", "consensus", "mcp"
PAPER_SEARCH_PROVIDER=

# LLM Configuration
# Optional: LLM provider (default: "zai")
PAPER_LLM_PROVIDER=
# Optional: LLM model name (default: "glm-5-turbo")
PAPER_LLM_MODEL=

# Semantic Scholar
# Optional: API key for higher rate limits
S2_API_KEY=

# Crossref
# Optional: Polite pool email for better rate limits
CROSSREF_POLITE_EMAIL=

# OpenAlex
# Optional: Email for polite pool
OPENALEX_EMAIL=
# Optional: API key
OPENALEX_API_KEY=

# PubMed / NCBI
# Optional: API key for higher rate limits (10 req/s vs 3 req/s)
NCBI_API_KEY=
# Optional: Tool name for NCBI API
NCBI_TOOL=
# Optional: Your email for NCBI API
USER_EMAIL=

# Consensus
# Optional: API key for Consensus search
CONSENSUS_API_KEY=

# Screening
# Optional: Minimum evidence tier for screening (default: "Tier 3")
PAPER_SCREEN_MIN_TIER=

# Thesaurus
# Optional: Thesaurus profile (default: "lite")
PAPER_THESAURUS_PROFILE=
# Optional: Thesaurus database path
PAPER_THESAURUS_DB=

# Trifecta MCP
# Optional: "off" (default), "real"
MCP_TRIFECTA_MODE=

# Testing
# Optional: Set to "1" to enable live Zotero integration tests
RUN_LIVE_ZOTERO_TESTS=
# Optional: Set to "1" to enable Consensus smoke tests
RUN_CONSENSUS_SMOKE=
# Optional: Set to "1" to enable MCP search smoke tests
RUN_MCP_SMOKE=
