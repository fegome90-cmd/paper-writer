verification/local-data/*.local.yaml
verification/local-data/*.pdf
verification/reports/

# Claude Code — only exclude ephemeral/session artifacts
.claude/context_memory/
.claude/context-memory-id
.claude/todos/

# Other agent tooling
openspec/

# Trifecta ephemeral cache (regenerated by `trifecta index`; SSOT is .trifecta/graph.db)
.trifecta/cache/

# Node toolchain deps (package.json and lock are tracked)
tools/node/node_modules/

# External tool clones (not part of this repo)
gemini-autoresearch/
